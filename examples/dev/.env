APP_NAME=MindJournal
VERSION=0.0.1
DEBUG=1
SECRET_KEY=<Base64-encoded PEM EdDSA key>
ALLOWED_ORIGINS=http://localhost

MAIL_USERNAME=<username>
MAIL_PASSWORD=<password>
MAIL_HOSTNAME=<hostname>
MAIL_PORT=<port>
EMAIL_CONFIRMATION_URL="http://localhost/api/v1/auth/confirm-email?token="

AUTH_SERVICE=auth:50051
WELLNESS_SERVICE=wellness:50051
KAFKA_SERVICE=kafka:9092

POSTGRES_DB=mind_journal
POSTGRES_USER=<username>
POSTGRES_PASSWORD=<password>
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_DB=0
REDIS_USER=default
REDIS_PASSWORD=<password>
REDIS_HOST=redis
REDIS_PORT=6379

GF_SECURITY_ADMIN_USER=<username>
GF_SECURITY_ADMIN_PASSWORD=<password>
